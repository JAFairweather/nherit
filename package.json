{
  "name": "nherit",
  "version": "0.1.0",
  "description": "Family break-glass digital legacy vault on nostr — one self-maintained estate record, revocable per-beneficiary access, recovery from a piece of paper. Built on NIP-DA Scoped Data Grants.",
  "type": "module",
  "scripts": {
    "smoke": "node test/smoke.mjs",
    "smoke:local": "node test/smoke.mjs --local",
    "escrow:test": "node test/escrow.mjs && node test/escrow-daemon.mjs",
    "shamir": "node test/shamir.mjs",
    "paper": "node test/paper.mjs",
    "invite": "node test/invite.mjs",
    "e2e": "node test/e2e.mjs",
    "egress": "node test/egress.mjs",
    "web": "node app/serve.mjs",
    "escrow": "node escrow/bin/nherit-escrow.mjs",
    "sync-lib": "cp ../nip-demo/nipxx.mjs ../nip-demo/liverelay.mjs ../nip-demo/relay.mjs lib/"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@paulmillr/qr": "^0.3.0",
    "nostr-tools": "^2.23.9",
    "slip39": "^0.1.9",
    "ws": "^8.0.0"
  },
  "license": "MIT"
}
